# ====================================
# Seif's Shell Exports & Environment
# ====================================

# --------- Named Directories ---------
hash -d dev=~/Development
hash -d dot=~/Development/macos-dot-files/
hash -d dl=~/Downloads

# --------- fzf (catppuccin macchiato) ---------
export FZF_DEFAULT_OPTS=" \
--height 40% --layout=reverse --border \
--color=bg+:#363A4F,bg:#24273A,spinner:#F4DBD6,hl:#ED8796 \
--color=fg:#CAD3F5,header:#ED8796,info:#C6A0F6,pointer:#F4DBD6 \
--color=marker:#B7BDF8,fg+:#CAD3F5,prompt:#C6A0F6,hl+:#ED8796 \
--color=selected-bg:#494D64 \
--color=border:#6E738D,label:#CAD3F5"

export FZF_DEFAULT_COMMAND='eza -la --color=always --sort=modified'

# fzf Ctrl+T - file picker preview using bat
export FZF_CTRL_T_OPTS="--preview 'bat --style=numbers --color=always --line-range :500 {}'"

# fzf Ctrl+R - history search preview
export FZF_CTRL_R_OPTS="--preview 'echo {}' --preview-window=down:3:hidden:wrap"

# --------- bat ---------
export MANPAGER="sh -c 'sed -u -e \"s/\\x1B\[[0-9;]*m//g; s/.\\x08//g\" | bat -p -lman'"
export BAT_THEME="Catppuccin Frappe"
export BAT_THEME_DARK="Catppuccin Mocha"
export BAT_THEME_LIGHT="Catppuccin Latte"

# --------- misc ---------
export ENABLE_LSP_TOOLS=1
